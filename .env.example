# =============================================================================
# OmniSpace — Root Environment Variables
#
# Copy this file and fill in the values:
#   cp .env.example .env
#
# ⚠ NEVER commit the .env file to version control!
# =============================================================================

# ─── PostgreSQL ────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-this-strong-postgres-password
POSTGRES_DB=omnispace
POSTGRES_PORT=5432

# ─── Redis ─────────────────────────────────────────────────────────────────
REDIS_PORT=6379
REDIS_PASSWORD=change-this-strong-redis-password

# ─── Backend ───────────────────────────────────────────────────────────────
PORT=3000
API_PREFIX=api/v1
NODE_ENV=production
FRONTEND_URL=http://localhost        # Change to your domain in production

# JWT — generate with: openssl rand -hex 64
JWT_SECRET=change-this-to-a-very-long-random-secret-generated-with-openssl
JWT_EXPIRES_IN=7d
COOKIE_NAME=access_token

# ─── Frontend ──────────────────────────────────────────────────────────────
# When served via Nginx reverse proxy, use a relative path (recommended):
VITE_API_BASE_URL=/api/v1

# When running frontend separately (dev without Nginx):
# VITE_API_BASE_URL=http://localhost:3000/api/v1
