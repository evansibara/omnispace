generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────────────────────────────────────────────────────────────────────
// ENUMS
// ──────────────────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  PROJECT_MANAGER
  DEVELOPER
  CLIENT
}

enum TenantPlan {
  FREE
  STARTER
  AGENCY
  ENTERPRISE
}

enum ProjectStatus {
  PLANNING
  ACTIVE
  ON_HOLD
  COMPLETED
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum ReportJobStatus {
  QUEUED
  PROCESSING
  READY
  FAILED
}

// ──────────────────────────────────────────────────────────────────────────
// MODELS
// ──────────────────────────────────────────────────────────────────────────

model Tenant {
  id        String     @id @default(uuid())
  name      String
  slug      String     @unique
  plan      TenantPlan @default(FREE)
  logoUrl   String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  users              User[]
  clientOrganizations ClientOrganization[]
  projects           Project[]
  tasks              Task[]
  comments           Comment[]
  reportJobs         ReportJob[]

  @@map("tenants")
}

model User {
  id         String    @id @default(uuid())
  tenantId   String
  fullName   String
  email      String    @unique
  password   String
  role       UserRole
  avatarUrl  String?
  jobTitle   String?
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // A CLIENT user is the single contact person for one external client org
  clientOrganization ClientOrganization?

  managedProjects  Project[]            @relation("ProjectManager")
  teamMemberships  ProjectTeamMember[]
  assignedTasks    Task[]               @relation("TaskAssignee")
  comments         Comment[]            @relation("CommentAuthor")

  @@index([tenantId])
  @@map("users")
}

/// The external client company a project belongs to.
/// `contactUser` is the CLIENT-role User who logs into the Client Portal.
model ClientOrganization {
  id            String   @id @default(uuid())
  tenantId      String
  companyName   String
  contactUserId String   @unique
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant      Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contactUser User      @relation(fields: [contactUserId], references: [id], onDelete: Cascade)
  projects    Project[]

  @@index([tenantId])
  @@map("client_organizations")
}

model Project {
  id               String        @id @default(uuid())
  tenantId         String
  title            String
  description      String        @default("")
  status           ProjectStatus @default(PLANNING)
  clientId         String
  projectManagerId String
  targetDeadline   DateTime
  completionRate   Float         @default(0)
  taskCount        Int           @default(0)
  taskCountDone    Int           @default(0)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  tenant         Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  client         ClientOrganization  @relation(fields: [clientId], references: [id], onDelete: Restrict)
  projectManager User                @relation("ProjectManager", fields: [projectManagerId], references: [id], onDelete: Restrict)

  team       ProjectTeamMember[]
  tasks      Task[]
  comments   Comment[]
  reportJobs ReportJob[]

  @@index([tenantId])
  @@index([clientId])
  @@index([projectManagerId])
  @@map("projects")
}

/// Many-to-many join table between Project and User (the assigned team).
model ProjectTeamMember {
  id        String   @id @default(uuid())
  projectId String
  userId    String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([projectId])
  @@index([userId])
  @@map("project_team_members")
}

model Task {
  id          String       @id @default(uuid())
  tenantId    String
  projectId   String
  title       String
  description String       @default("")
  status      TaskStatus   @default(TODO)
  priority    TaskPriority @default(MEDIUM)
  assigneeId  String?
  dueDate     DateTime?
  position    Int          @default(0)
  commentCount Int         @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project  Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee User?    @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  comments Comment[]

  @@index([tenantId])
  @@index([projectId, status])
  @@index([assigneeId])
  @@map("tasks")
}

model Comment {
  id        String   @id @default(uuid())
  tenantId  String
  projectId String
  taskId    String?
  authorId  String
  body      String
  createdAt DateTime @default(now())

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task    Task?   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author  User    @relation("CommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([projectId])
  @@index([taskId])
  @@map("comments")
}

model ReportJob {
  id          String          @id @default(uuid())
  tenantId    String
  projectId   String
  status      ReportJobStatus @default(QUEUED)
  periodLabel String
  downloadUrl String?
  requestedAt DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([projectId])
  @@map("report_jobs")
}
